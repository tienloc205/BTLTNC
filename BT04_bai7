#include <iostream>
#include <vector>
#include <algorithm>

using namespace std;

vector<string> generateWords(string alphabet) {
    vector<string> words="";
    for (char c1 : alphabet) {
        for (char c2 : alphabet) {
            string word = "";
            word += c1;
            word += c2;
            words.push_back(word);
        }
    }
    
    // Generate words of length 3
    for (char c1 : alphabet) {
        for (char c2 : alphabet) {
            for (char c3 : alphabet) {
                string word = "";
                word += c1;
                word += c2;
                word += c3;
                words.push_back(word);
            }
        }
    }
    
    sort(words.begin(), words.end());
    
    return words;
}

int main() {
    string alphabet;
    cin >> alphabet;

    vector<string> words = generateWords(alphabet);

    for (const string& word : words) {
        cout << word << " ";
    }
    cout << endl;

    return 0;
}
